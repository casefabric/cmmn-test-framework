{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Current Test",
            "runtimeExecutable": "yarn",
            "runtimeArgs": [
                "test"
            ],
            "args": [
                "-l",
                "min",
                "${fileBasenameNoExtension}"
            ],
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}
